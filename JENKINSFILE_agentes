def logAgentInfo() {
    echo WORKSPACE
    echo env.NODE_NAME
    sh 'whoami'
    sh 'hostname'
  }
  pipeline {
      agent none
      stages {
          stage('Get Code') {
              agent { label 'default' }
              steps {
                  script { logAgentInfo() }
                  git 'https://github.com/luiinge/DevOps-helloworld'
                  stash includes: '**', name: 'src'
                  cleanWs()
              }
          }
          stage('Tests & Analysis') {
              parallel {
                  stage('Unit') {
                      agent { label 'linux' }
                      steps {
                         script { logAgentInfo() }
                         unstash name: 'src'
                         catchError(buildResult: 'SUCCESS', stageResult: 'SUCCESS') {
                           sh 'PYTHONPATH=. python3 -m coverage run --source=app --omit=app/__init__.py,app/api.py -m pytest --junitxml=test-unit.xml test/unit --verbose'
                         }
                         junit 'test-unit.xml'
                         stash includes: '.coverage', name: 'coverage'
                         cleanWs()
                      }
                  }
                  stage('Rest') {
                      agent { label 'linux' }
                      steps {
                          script { logAgentInfo() }
                          unstash name: 'src'
                          catchError(buildResult: 'SUCCESS', stageResult: 'SUCCESS') {
                            sh '''
                               FLASK_APP=app/api.py flask run &
                               FLASK_PID=$!
                               java -jar /home/luis/bin/wiremock-standalone-3.13.2.jar --port 9090 --root-dir test/wiremock &
                               WIREMOCK_PID=$!
                               sleep 3
                               PYTHONPATH=. pytest --junitxml=test-it.xml test/rest --verbose
                               kill $WIREMOCK_PID
                               kill $FLASK_PID
                            '''
                          }
                          junit 'test-it.xml'
                          cleanWs()
                      }
                  }
                  stage('Static') {
                      agent { label 'linux' }
                      steps {
                          script { logAgentInfo() }
                          unstash name: 'src'
                          sh 'flake8 --format=pylint --exit-zero app > flake8.out'
                          catchError(buildResult: 'SUCCESS', stageResult: 'SUCCESS') {
                            recordIssues tools: [flake8(pattern:'flake8.out')],
                                  qualityGates: [
                                      [threshold:8,  type:'TOTAL', unstable:true],
                                      [threshold:10, type:'TOTAL', unstable:false]
                                  ]
                          }
                          cleanWs()
                      }
                  }
                  stage('Security Test') {
                      agent { label 'linux' }
                      steps {
                         script { logAgentInfo() }
                         unstash name: 'src'
                         sh returnStatus:true, script: 'bandit -r . -f custom -o bandit.out --msg-template "{abspath}:{line}: {severity}: {test_id}: {msg}"'
                         catchError(buildResult: 'SUCCESS', stageResult: 'SUCCESS') {
                            recordIssues tools: [pyLint(pattern:'bandit.out')],
                                  qualityGates: [
                                      [threshold:2, type:'TOTAL', unstable:true],
                                      [threshold:4, type:'TOTAL', unstable:false]
                                  ]
                          }
                          cleanWs()
                      }
                  }
              }
          }
          stage('Performance & Coverage') {
              parallel {
                  stage('Performance') {
                      agent { label 'linux' }
                      steps {
                        script { logAgentInfo() }
                        unstash name: 'src'
                        sh '''
                              FLASK_APP=app/api.py flask run &
                              FLASK_PID=$!
                              sleep 3
                              /home/luis/bin/apache-jmeter-5.6.3/bin/jmeter -n -t test/jmeter/flask.jmx -l flask.jtl
                              kill $FLASK_PID
                            '''
                       perfReport sourceDataFiles: 'flask.jtl'
                       cleanWs()
                      }
                  }
                  stage('Coverage') {
                      agent { label 'linux' }
                      steps {
                        script { logAgentInfo() }
                        unstash name: 'src'
                        unstash name: 'coverage'
                        sh 'python3 -m coverage xml'
                        recordCoverage tools: [[parser: 'COBERTURA', pattern: 'coverage.xml']],
                            qualityGates: [
                                [threshold: 85.0, metric: 'LINE',   baseline: 'PROJECT', criticality: 'FAILURE'],
                                [threshold: 95.0, metric: 'LINE',   baseline: 'PROJECT', criticality: 'UNSTABLE'],
                                [threshold: 80.0, metric: 'BRANCH', baseline: 'PROJECT', criticality: 'FAILURE'],
                                [threshold: 90.0, metric: 'BRANCH', baseline: 'PROJECT', criticality: 'UNSTABLE']
                            ]
                        cleanWs()
                      }
                  }
              }
          }
      }
  }
